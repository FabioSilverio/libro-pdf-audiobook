# ============================================
# PDF to Audiobook - Environment Configuration
# ============================================

# Summarization (OPTIONAL - App works without these!)
# The app uses HuggingFace free API by default (no key needed)
# Uncomment below to use OpenAI instead (higher quality)
# OPENAI_API_KEY=sk-your-openai-key-here

# Text-to-Speech (OPTIONAL - Browser TTS is free!)
# The app uses browser Speech Synthesis by default (completely free)
# Uncomment below to use ElevenLabs for premium voices
# ELEVENLABS_API_KEY=your-elevenlabs-key-here
# Get your free API key at: https://elevenlabs.io/app/sign-up
# Free tier: 10,000 characters/month

# Maximum file size in bytes (50MB default)
MAX_FILE_SIZE=52428800

# Storage paths
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting (requests per minute)
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_GENERAL=100

# Task cleanup (hours)
TASK_RETENTION_HOURS=24
